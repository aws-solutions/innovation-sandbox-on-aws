                                "Arn"
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    "/*"
                  ]
                ]
              }
            }
          ],
          "Version": "2012-10-17"
        },
        "PolicyName": "OrganizationsPolicyFD65B3A6",
        "Roles": [
          {
            "Ref": "OrgMgtRoleADB4C27C"
          }
