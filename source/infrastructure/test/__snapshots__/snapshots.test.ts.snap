            "Arn": {
              "Fn::GetAtt": [
                "AccountLifeCycleEventsToSqsToLambdaAccountLifeCycleEventsQueue2EC48316",
                "Arn"
              ]
            },
            "Id": "Target0",
            "RetryPolicy": {
              "MaximumEventAgeInSeconds": 14400,
              "MaximumRetryAttempts": 3
            },
            "SqsParameters": {
              "MessageGroupId": "AccountLifeCycleEvents"
            }
          }
        ]
      }
