                        },
                      ],
                    },
                    "/",
                    {
                      "Fn::FindInMap": [
                        "Mapping",
                        "context",
                        "solutionName",
                        {
                          "DefaultValue": "",
                        },
                      ],
                    },
                    "-account-cleaner:",
                    {
                      "Fn::If": [
                        "UseStableTaggingCondition",
                        {
