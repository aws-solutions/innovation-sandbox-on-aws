    "InnovationSandboxProtectISBScp": {
      "Properties": {
        "Content": {
          "Statement": [
            {
              "Action": "*",
              "Condition": {
                "ArnNotLike": {
                  "aws:PrincipalARN": [
                    {
                      "Fn::Join": [
                        "",
                        [
                          "arn:aws:iam::*:role/InnovationSandbox-",
