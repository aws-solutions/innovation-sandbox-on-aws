              "Ref": "ISBEventBusD5514129",
            },
            "ISB_NAMESPACE": {
              "Ref": "Namespace",
            },
            "NODE_OPTIONS": "--enable-source-maps",
            "ORG_MGT_ROLE_ARN": {
              "Fn::Join": [
                "",
                [
                  "arn:",
                  {
                    "Ref": "AWS::Partition",
                  },
                  ":iam::",
                  {
                    "Ref": "OrgMgtAccountId",
                  },
                  ":role/InnovationSandbox-",
                  {
                    "Ref": "Namespace",
                  },
                  "-OrgMgtRole",
                ],
              ],
            },
            "POWERTOOLS_LOG_LEVEL": {
              "Fn::FindInMap": [
                "Mapping",
                "context",
                "logLevel",
                {
                  "DefaultValue": "",
                },
              ],
            },
            "POWERTOOLS_SERVICE_NAME": "innovation-sandbox",
            "USER_AGENT_EXTRA": "AwsSolution/SO0284/v1.2.3",
          },
        },
        "FunctionName": {
          "Fn::Join": [
            "",
            [
              "ISB-AccountDriftMonitoring-",
