                },
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:",
                      {
                        "Ref": "AWS::Partition"
                      },
                      ":organizations::",
                      {
                        "Ref": "AWS::AccountId"
                      },
                      ":root/",
                      {
                        "Fn::Select": [
                          1,
                          {
                            "Fn::Split": [
                              "/",
                              {
                                "Fn::GetAtt": [
                                  "InnovationSandboxAccountPoolOu",
                                  "Arn"
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      "/*"
                    ]
                  ]
                }
              ]
            },
            {
              "Action": "organizations:DescribeAccount",
              "Effect": "Allow",
              "Resource": {
                "Fn::Join": [
                  "",
                  [
                    "arn:",
                    {
                      "Ref": "AWS::Partition"
                    },
                    ":organizations::",
                    {
                      "Ref": "AWS::AccountId"
                    },
                    ":account/",
                    {
                      "Fn::Select": [
